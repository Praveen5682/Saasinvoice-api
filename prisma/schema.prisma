generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  clients   Client[]
  projects  Project[]
  estimates Estimate[]
  invoices  Invoice[]
  payments  Payment[]

  @@map("organizations")
}

model User {
  id              String        @id @default(uuid())
  orgId           String?       @map("org_id")
  name            String        @db.VarChar(255)
  email           String        @unique @db.VarChar(255)
  password        String        @db.VarChar(255)
  role            String?       @default("user") @db.VarChar(50)
  isEmailVerified Boolean?      @default(false) @map("is_email_verified")
  companyName     String?       @map("company_name")
  companyLogo     String?       @map("company_logo")
  address         String?
  phone           String?
  gstNumber       String?       @map("gst_number")
  planType        String?       @map("plan_type")
  planExpiry      DateTime?     @map("plan_expiry")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization    Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  // Relations preserved for legacy/other modules
  clients         Client[]
  invoices        Invoice[]
  invoiceItems    InvoiceItem[]
  payments        Payment[]
  subscriptions   Subscription[]
  reminders       Reminder[]
  products        Product[]
  estimates       Estimate[]
  projects        Project[]

  @@map("users")
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime @map("expires_at")

  @@map("email_otps")
}

model Client {
  id            String       @id @default(uuid())
  orgId         String?      @map("org_id")
  userId        String?      @map("user_id") // legacy
  name          String
  clientType    String?      @map("client_type")
  contactPerson String?      @map("contact_person")
  email         String?
  phone         String?
  gstin         String?
  pan           String?
  placeOfSupply String?      @map("place_of_supply")
  address       String?
  city          String?
  state         String?
  zip           String?
  country       String?
  companyProfession String?  @map("company_profession")
  paymentTerms  String?      @map("payment_terms")
  notes         String?      @db.Text
  status        Int?         @default(1)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  organization  Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  projects      Project[]
  estimates     Estimate[]
  invoices      Invoice[]
  subscriptions Subscription[]

  @@map("clients")
}

model Project {
  id          String       @id @default(uuid())
  orgId       String?      @map("org_id")
  userId      String?      @map("user_id") // legacy
  clientId    String       @map("client_id")
  name        String
  description String?      @db.Text
  status      String?      @default("active")
  startDate   DateTime?    @db.Date @map("start_date")
  endDate     DateTime?    @db.Date @map("end_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  estimates    Estimate[]
  invoices     Invoice[]

  @@map("projects")
}

model Estimate {
  id          String       @id @default(uuid())
  orgId       String?      @map("org_id")
  userId      String?      @map("user_id") // legacy
  clientId    String       @map("client_id")
  projectId   String?      @map("project_id")
  estimateNo  String       @unique @map("estimate_no")
  status      String?      @default("draft")
  totalAmount Decimal?     @default(0) @db.Decimal(14, 2) @map("total_amount")
  subtotal    Decimal?     @db.Decimal(14, 2)
  issueDate   DateTime?    @db.Date @map("issue_date")
  expiryDate  DateTime?    @db.Date @map("expiry_date")
  notes       String?      @db.Text
  currency    String?      @default("INR")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  items        EstimateItem[]

  @@map("estimates")
}

model EstimateItem {
  id          String   @id @default(uuid())
  estimateId  String   @map("estimate_id")
  description String
  quantity    Int?     @default(1)
  unitPrice   Decimal  @db.Decimal(14, 2) @map("unit_price")
  taxRate     Decimal? @default(0) @db.Decimal(5, 2) @map("tax_rate")
  amount      Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_items")
}

model Invoice {
  id              String        @id @default(uuid())
  orgId           String?       @map("org_id")
  userId          String?       @map("user_id") // legacy
  clientId        String?       @map("client_id")
  projectId       String?       @map("project_id")
  invoiceNo       String        @unique @map("invoice_no")
  status          String?       @default("pending")
  totalAmount     Decimal?      @default(0) @db.Decimal(14, 2) @map("total_amount")
  subtotal        Decimal?      @db.Decimal(14, 2)
  amountPaid      Decimal?      @default(0) @db.Decimal(14, 2) @map("amount_paid")
  balanceDue      Decimal?      @default(0) @db.Decimal(14, 2) @map("balance_due")
  issueDate       DateTime?     @db.Date @map("issue_date")
  dueDate         DateTime?     @db.Date @map("due_date")
  notes           String?       @db.Text
  billingAddress  String?       @db.Text @map("billing_address")
  shippingAddress String?       @db.Text @map("shipping_address")
  bankDetails     String?       @db.Text @map("bank_details")
  signature       String?       @db.Text
  clientName      String?       @map("client_name")
  clientEmail     String?       @map("client_email")
  clientPhone     String?       @map("client_phone")
  clientGstin     String?       @map("client_gstin")
  clientPan       String?       @map("client_pan")
  clientWebsite   String?       @map("client_website")
  placeOfSupply   String?       @map("place_of_supply")
  currency        String?       @default("INR")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization    Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  items           InvoiceItem[]
  payments        Payment[]
  reminders       Reminder[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String?  @map("invoice_id")
  userId      String?  @map("user_id") // legacy
  description String
  quantity    Int?     @default(1)
  unitPrice   Decimal  @db.Decimal(14, 2) @map("unit_price")
  taxRate     Decimal? @default(0) @db.Decimal(5, 2) @map("tax_rate")
  amount      Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id             String   @id @default(uuid())
  orgId          String?  @map("org_id")
  userId         String?  @map("user_id") // legacy
  invoiceId      String?  @map("invoice_id")
  amount         Decimal  @db.Decimal(14, 2)
  method         String
  transactionId  String?  @unique @map("transaction_id")
  status         String?  @default("captured")
  paymentDate    DateTime @map("payment_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ── Legacy Models (Kept for compatibility, updated to UUIDs) ──

model Subscription {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  clientId        String?  @map("client_id")
  planName        String   @map("plan_name")
  amount          Decimal  @db.Decimal(14, 2)
  status          String?  @default("active")
  cycle           String?  @default("monthly")
  startDate       DateTime @db.Date @map("start_date")
  nextBillingDate DateTime @db.Date @map("next_billing_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Reminder {
  id           String    @id @default(uuid())
  userId       String?   @map("user_id")
  invoiceId    String?   @map("invoice_id")
  type         String?   @default("email")
  reminderDate DateTime  @map("reminder_date")
  lastSent     DateTime? @map("last_sent")
  status       String?   @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Product {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(14, 2)
  category    String?
  type        String?  @default("service")
  status      Int?     @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("products")
}
