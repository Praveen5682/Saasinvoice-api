generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model users {
  id                Int       @id @default(autoincrement())
  name              String    @db.VarChar(255)
  email             String    @unique @db.VarChar(255)
  password          String    @db.VarChar(255)
  role              String?   @default("user") @db.VarChar(50)
  is_email_verified Boolean?  @default(false)
  company_name      String?
  company_logo      String?
  address           String?
  phone             String?
  gst_number        String?
  plan_type         String?
  plan_expiry       DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  clients       clients[]
  invoices      invoices[]
  invoice_items invoice_items[]
  payments      payments[]
  subscriptions subscriptions[]
  reminders     reminders[]
  products      products[]
}

model email_otps {
  id         Int      @id @default(autoincrement())
  email      String
  otp        String
  expires_at DateTime
}

model clients {
  id              Int      @id @default(autoincrement())
  user_id         Int?
  name            String
  client_type     String?
  contact_person  String?
  email           String?
  phone           String?
  gstin           String?
  pan             String?
  place_of_supply String?
  address         String?
  city            String?
  state           String?
  zip             String?
  payment_terms   String?
  notes           String?  @db.Text
  status          Int?     @default(1)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user          users?          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  invoices      invoices[]
  subscriptions subscriptions[]
}

model invoices {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  client_id        Int?
  invoice_no       String    @unique
  status           String?   @default("pending")
  total_amount     Decimal?  @default(0) @db.Decimal(14, 2)
  subtotal         Decimal?  @db.Decimal(14, 2)
  amount_paid      Decimal?  @default(0) @db.Decimal(14, 2)
  balance_due      Decimal?  @default(0) @db.Decimal(14, 2)
  issue_date       DateTime? @db.Date
  due_date         DateTime? @db.Date
  notes            String?   @db.Text
  billing_address  String?   @db.Text
  shipping_address String?   @db.Text
  bank_details     String?   @db.Text
  signature        String?   @db.Text
  client_name      String?
  client_email     String?
  client_phone     String?
  client_gstin     String?
  client_pan       String?
  client_website   String?
  place_of_supply  String?
  currency         String?   @default("INR")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user          users?          @relation(fields: [user_id], references: [id])
  client        clients?        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  invoice_items invoice_items[]
  payments      payments[]
  reminders     reminders[]
}

model invoice_items {
  id          Int      @id @default(autoincrement())
  invoice_id  Int?
  user_id     Int?
  description String
  quantity    Int?     @default(1)
  unit_price  Decimal  @db.Decimal(14, 2)
  tax_rate    Decimal? @default(0) @db.Decimal(5, 2)
  amount      Decimal  @db.Decimal(14, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  invoice invoices? @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  user    users?    @relation(fields: [user_id], references: [id])
}

model payments {
  id             Int      @id @default(autoincrement())
  user_id        Int?
  invoice_id     Int?
  amount         Decimal  @db.Decimal(14, 2)
  method         String
  transaction_id String?  @unique
  status         String?  @default("captured")
  payment_date   DateTime
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user    users?    @relation(fields: [user_id], references: [id])
  invoice invoices? @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                Int      @id @default(autoincrement())
  user_id           Int?
  client_id         Int?
  plan_name         String
  amount            Decimal  @db.Decimal(14, 2)
  status            String?  @default("active")
  cycle             String?  @default("monthly")
  start_date        DateTime @db.Date
  next_billing_date DateTime @db.Date
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user   users?   @relation(fields: [user_id], references: [id])
  client clients? @relation(fields: [client_id], references: [id], onDelete: Cascade)
}

model reminders {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  invoice_id    Int?
  type          String?   @default("email")
  reminder_date DateTime
  last_sent     DateTime?
  status        String?   @default("pending")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  user    users?    @relation(fields: [user_id], references: [id])
  invoice invoices? @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
}

model products {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(14, 2)
  category    String?
  type        String?  @default("service")
  status      Int?     @default(1)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user users? @relation(fields: [user_id], references: [id])
}
